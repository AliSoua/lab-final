{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES6",
    "moduleResolution": "Node",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}